rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow anyone to sign up/login (User & OB)
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Consultation Rules
    match /consultations/{consultationId} {
      // Allow creating a consultation (Patient Guest Mode)
      allow create: if true;
      
      // Allow reading (Doctors need to query, Patients need to listen)
      allow read: if true;
      
      // Allow updating (Doctors claiming, updating assessments)
      // Ideally check request.auth != null, but for debugging/demo start with true
      allow update: if true; 
    }

    // OB assessment records (offline-first sync target)
    match /assessments/{assessmentId} {
      // Doctor can read only their own records
      allow read: if request.auth != null
                  && resource.data.doctorId == request.auth.uid;

      // Create only if payload belongs to the authenticated doctor
      allow create: if request.auth != null
                    && request.resource.data.doctorId == request.auth.uid;

      // Update/delete only for owning doctor
      allow update, delete: if request.auth != null
                            && resource.data.doctorId == request.auth.uid;
    }

    // Remote MEC config used by the app (public read)
    match /mec_config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}

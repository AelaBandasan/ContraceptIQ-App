# ─── ContraceptIQ API Configuration ───────────────────────────────────────────
#
# Copy this file to .env and set the value for your machine.
# .env is gitignored — each developer must configure their own.
#
# HOW TO FIND YOUR LAN IP:
#   Mac/Linux : run `ifconfig | grep "inet "` → look for 192.168.x.x
#   Windows   : run `ipconfig` in CMD → look for "IPv4 Address" (192.168.x.x)
#
# The Flask server must be running on the same machine as your IP below.
# Start it with: cd flask-api && python app.py
#
# ─── Physical Device (most common) ────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://192.168.x.x:5000

# ─── Android Emulator ─────────────────────────────────────────────────────────
# Uncomment this line instead if running on Android emulator (10.0.2.2 maps to host)
#EXPO_PUBLIC_API_URL=http://10.0.2.2:5000

# ─── iOS Simulator ────────────────────────────────────────────────────────────
# Uncomment this line instead if running on iOS Simulator
#EXPO_PUBLIC_API_URL=http://localhost:5000
